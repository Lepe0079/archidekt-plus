{
  "manifest_version": 3,
  "name": "Archidekt Plus",
  "version": "0.2.0",
  "description": "Adds Oracle-tag search, release-date sorting, and a deck-wide Oracle tag browser to Archidekt.",
  "browser_specific_settings": {
    "gecko": {
      "id": "archidekt-plus@local.ext",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "host_permissions": ["https://archidekt.com/*"],
  "content_scripts": [
    {
      "matches": ["https://archidekt.com/*"],
      "js": ["content/content.js", "content/deck-tags.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/page-hook.js", "data/otags.json"],
      "matches": ["https://archidekt.com/*"]
    }
  ]
}
